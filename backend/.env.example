# Environnement
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/documents_perdus

# JWT
JWT_SECRET=changez-moi-en-production-avec-une-cle-securisee
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Admin
ADMIN_CODE=ADMIN2026

# Service IA
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT=30000

# LLM (Anthropic Claude ou OpenAI)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxx
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.3

# Notifications - Email
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@oufarez.com
EMAIL_FROM_NAME=OUFAREZ - Documents Perdus

# Notifications - SMS
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Matching
MATCH_THRESHOLD=0.72
MATCH_WINDOW_DAYS=30
MATCH_MAX_CANDIDATES=10
WEIGHT_NLP=0.4
WEIGHT_LLM=0.5
WEIGHT_GEO=0.1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_DEST=./uploads

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

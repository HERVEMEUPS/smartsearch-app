# Configuration Production pour Render.com
# Copiez ces variables dans les "Environment Variables" de votre service Render

NODE_ENV=production
PORT=10000

# MongoDB Atlas (À CONFIGURER - voir GUIDE_RAPIDE_MONGODB_RENDER.md)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/documents_perdus?retryWrites=true&w=majority

# JWT (Généré automatiquement par Render ou créez une chaîne aléatoire de 32+ caractères)
JWT_SECRET=changez-moi-en-production-avec-une-chaine-ultra-securisee-aleatoire
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Admin
ADMIN_CODE=ADMIN2026

# CORS - Autorisez votre frontend Render
CORS_ORIGIN=https://smartsearch-frontend.onrender.com,https://smartsearch-backend-pxw5.onrender.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_DEST=./uploads

# Logs
LOG_LEVEL=info
LOG_FORMAT=combined

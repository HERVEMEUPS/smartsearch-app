{
  "name": "backend",
  "version": "2.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:legacy": "node server.js",
    "dev:legacy": "nodemon server.js",
    "migrate": "node scripts/migrate-json-to-mongo.js",
    "seed": "node scripts/seed-data.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "documents",
    "perdus",
    "ia",
    "cameroun",
    "oufarez"
  ],
  "author": "HERVEMEUPS",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.17.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fuse.js": "^7.4.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "string-similarity": "^4.0.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.4",
    "supertest": "^6.3.4"
  },
  "description": "Backend API pour le système intelligent de gestion de documents perdus",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}

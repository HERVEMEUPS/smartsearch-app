# 🔐 Variables d'environnement - OUFAREZ Documents Perdus
# Copier ce fichier en .env et ajuster les valeurs

# ========================================
# BACKEND API (Node.js)
# ========================================

NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://admin:oufarez2026@localhost:27017/documents_perdus?authSource=admin

# JWT
JWT_SECRET=changez-moi-en-production-avec-une-cle-tres-securisee-aleatoire
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=10

# Admin
ADMIN_CODE=ADMIN2026

# Service IA
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_DEST=./uploads

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# ========================================
# SERVICE IA (Python/FastAPI)
# ========================================

# LLM (Anthropic Claude ou OpenAI)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxxxxxxxxxx
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=30

# Embeddings
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_CACHE_DIR=./cache/embeddings

# spaCy
SPACY_MODEL=fr_core_news_sm

# Matching Parameters
MATCH_THRESHOLD=0.72
MATCH_WINDOW_DAYS=30
MATCH_MAX_CANDIDATES=10
WEIGHT_NLP=0.4
WEIGHT_LLM=0.5
WEIGHT_GEO=0.1

# ========================================
# NOTIFICATIONS (Optionnel)
# ========================================

# Email (SendGrid)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
EMAIL_FROM=noreply@oufarez.com
EMAIL_FROM_NAME=OUFAREZ - Documents Perdus

# SMS (Twilio)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+237600000000

# ========================================
# FRONTEND (React/Vite)
# ========================================

VITE_API_URL=http://localhost:3000
VITE_APP_NAME=OUFAREZ Documents Perdus
VITE_APP_VERSION=2.0.0

# ========================================
# DOCKER (Docker Compose)
# ========================================

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=oufarez2026
MONGO_INITDB_DATABASE=documents_perdus

# ========================================
# PRODUCTION (À configurer séparément)
# ========================================

# Activer HTTPS
# FORCE_HTTPS=true

# Domaine
# DOMAIN=documents-perdus.oufarez.com

# SSL Certificates
# SSL_CERT_PATH=/etc/letsencrypt/live/domain/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/domain/privkey.pem
